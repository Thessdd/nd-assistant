{
  "name": "nd-assistant",
  "private": true,
  "workspaces": [
    "app"
  ],
  "scripts": {
    "dev": "concurrently -n APP,VERCEL -c \"cyan,magenta\" \"npm --prefix app run dev -- --port 5173\" \"vercel dev --listen 3000\"",
    "build": "npm --prefix app run build",
    "lint": "npm --prefix app run lint",
    "typecheck": "npm --prefix app run typecheck"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "tsdav": "^2.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3",
    "vercel": "^44.1.0"
  }
}
